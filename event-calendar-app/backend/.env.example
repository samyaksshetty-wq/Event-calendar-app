# Copy this file to .env and fill in your own values

PORT=4000

# Any long random string - used to sign admin login tokens
JWT_SECRET=change_this_to_a_long_random_string

# Used only by the "npm run create-admin" script to create your admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# --- Supabase ---
# Database: Supabase dashboard -> Settings -> Database -> Connection string -> URI
# (use the "Transaction pooler" connection string, port 6543)
DATABASE_URL=postgresql://postgres.xxxxxxxx:your_db_password@aws-0-xx-xxxx-1.pooler.supabase.com:6543/postgres

# API: Supabase dashboard -> Settings -> API
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
